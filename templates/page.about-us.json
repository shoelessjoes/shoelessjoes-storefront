    "era_3": {
      "type": "image-with-text",
      "blocks": {
        "h3b": {
          "type": "heading",
          "settings": {
            "heading": "The Storm & Restoration — April 2025",
            "heading_size": "h2",
            "heading_tag": "h2"
          }
        },
        "t3b": {
          "type": "text",
          "settings": {
            "text": "<p><strong>A Rocky Start to a New Chapter.</strong> Just one week after new ownership took the reins, a major storm tore through the region, damaging the roof and causing significant flooding. The floors, walls, and ceiling had to be replaced — but we worked hard to keep the heart and soul of Shoeless Joe's intact.</p>",
            "text_size": "t2"
          }
        }
      },
