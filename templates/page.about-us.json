          "type": "heading",
          "settings": {
            "heading": "The Burke Family Era — 2025–Present",
            "heading_size": "h2",
            "heading_tag": "h2"
          }
        },
        "t4b": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Continuing the Story.</strong> Now operated by Dan and Kevin Burke, second-generation collectors, Shoeless Joe's enters a new chapter. Same local roots. Same collector spirit. A fresh look, ready for the next generation.</p>",
            "text_size": "t2"
          }
        }
