{
  "sections": {
    "hero_banner": {
      "type": "slideshow",
      "blocks": {
        "slide_hero": {
          "type": "slide",
          "settings": {
            "image_overlay_opacity": 25,
            "desktop_content_position": "md:justify-center md:items-center",
            "mobile_content_position": "justify-center items-center",
            "content_max_width": "m",
            "desktop_content_alignment": "center",
            "mobile_content_alignment": "center",
            "show_text_box": "always",
            "heading": "Sports Cards & Collectibles",
            "heading_size": "custom",
            "heading_size_custom": 4.2,
            "heading_tag": "h1",
            "text": "<p>Est. 1992 • Trusted Grader • Premium Selection</p>",
            "text_size": "t2",
            "button_label_1": "Browse Sealed Wax",
            "button_link_1": "/collections/sealed-wax",
            "button_style_1": "secondary",
            "button_style_1_show_arrow": true,
            "button_label_2": "Grading Services",
            "button_link_2": "/pages/psa-form",
            "button_style_2": "primary",
            "color_scheme": "scheme-1"
          }
        }
      },
      "block_order": ["slide_hero"],
      "settings": {
        "autoplay": "autoplay_with_pause",
        "change_slides_speed": 10,
        "desktop_section_height": 520,
        "mobile_section_height": 380,
        "color_scheme": "scheme-1"
      }
    },

    "brand_marquee": {
      "type": "icons-with-text",
      "blocks": {
        "psa_agent": {
          "type": "icon_with_text",
          "settings": {
            "icon": "shield_checkmark",
            "title": "<strong>PSA Authorized</strong>",
            "text": "Official Grading Agent"
          }
        },
        "topps_dealer": {
          "type": "icon_with_text",
          "settings": {
            "icon": "star",
            "title": "<strong>Official Dealer</strong>",
            "text": "Topps & Panini"
          }
        },
        "expert_staff": {
          "type": "icon_with_text",
          "settings": {
            "icon": "chat_bubbles",
            "title": "<strong>Expert Staff</strong>",
            "text": "Passionate Collectors"
          }
        },
        "brick_mortar": {
          "type": "icon_with_text",
          "settings": {
            "icon": "location",
            "title": "<strong>Visit Us</strong>",
            "text": "Cincinnati, Ohio"
          }
        }
      },
      "block_order": ["psa_agent", "topps_dealer", "expert_staff", "brick_mortar"],
      "settings": {
        "placement": "beside",
        "vertical_padding": 2,
        "icon_size": 3,
        "heading_size": "t5",
        "text_size": "t6"
      }
    },

    "sealed_wax_section": {
      "type": "featured-collection",
      "settings": {
        "collection": "sealed-wax",
        "products_to_show": 8,
        "desktop_layout": "carousel",
        "mobile_layout": "carousel",
        "columns_desktop": 4,
        "title": "Sealed Wax Products",
        "text": "<p>New product boxes, packs, and cases in original packaging</p>",
        "heading_size": "h2",
        "color_scheme": "scheme-1"
      }
    },

    "graded_cards_cta": {
      "type": "image-banner",
      "blocks": {
        "graded_heading": {
          "type": "heading",
          "settings": {
            "heading": "Graded Cards in Stock",
            "heading_size": "h2"
          }
        },
        "graded_text": {
          "type": "text",
          "settings": {
            "text": "<p>Browse our collection of professionally graded cards, sorted by sport and TCG</p>"
          }
        },
        "graded_button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "View Graded Cards",
            "button_link_1": "/pages/graded-inventory",
            "button_style_1": "secondary",
            "button_style_1_show_arrow": true
          }
        }
      },
      "block_order": ["graded_heading", "graded_text", "graded_button"],
      "settings": {
        "desktop_section_height": 380,
        "mobile_section_height": 320,
        "desktop_content_position": "md:justify-center md:items-center",
        "mobile_content_position": "justify-center items-center",
        "color_scheme": "scheme-2"
      }
    },

    "grading_services_cta": {
      "type": "rich-text",
      "blocks": {
        "grading_heading": {
          "type": "heading",
          "settings": {
            "heading": "Professional Grading Services",
            "heading_size": "h2"
          }
        },
        "grading_text": {
          "type": "text",
          "settings": {
            "text": "<p>Shoeless Joe's is a PSA Authorized Grading Agent. We offer weekly and monthly submission runs with upfront pricing, no surprises. Bring your cards in, and we'll handle the rest.</p>"
          }
        },
        "grading_button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Submit Cards for Grading",
            "button_link_1": "/pages/psa-form",
            "button_style_1": "secondary",
            "button_style_1_show_arrow": true
          }
        }
      },
      "block_order": ["grading_heading", "grading_text", "grading_button"],
      "settings": {
        "desktop_content_position": "center",
        "content_max_width": "m",
        "section_color_scheme": "scheme-2"
      }
    },

    "store_info": {
      "type": "icons-with-text",
      "blocks": {
        "location_info": {
          "type": "icon_with_text",
          "settings": {
            "icon": "location",
            "title": "<strong>6123 Bridgetown Rd</strong>",
            "text": "Cincinnati, OH 45248"
          }
        },
        "hours_info": {
          "type": "icon_with_text",
          "settings": {
            "icon": "clock",
            "title": "<strong>Visit in Person</strong>",
            "text": "See us for grading submissions"
          }
        },
        "contact_info": {
          "type": "icon_with_text",
          "settings": {
            "icon": "chat_bubbles",
            "title": "<strong>Questions?</strong>",
            "text": "Contact us anytime"
          }
        }
      },
      "block_order": ["location_info", "hours_info", "contact_info"],
      "settings": {
        "placement": "beside",
        "vertical_padding": 3,
        "icon_size": 2.8
      }
    }
  },
  "order": ["hero_banner", "brand_marquee", "sealed_wax_section", "graded_cards_cta", "grading_services_cta", "store_info"]
}
