# Copy this file to .env and fill in real values.
# Never commit .env — only this template.
# Real credentials are stored in 1Password. See docs/CREDENTIALS.md.

# ─── Shopify Admin API (PSA form → draft orders) ──────────────────
SHOPIFY_STORE=shoelessjoescards.myshopify.com
SHOPIFY_API_TOKEN=                              # shpat_xxx — Admin API access token
SHOPIFY_LOCATION_ID=72115847233
SHOPIFY_API_VERSION=2024-10

# ─── Google Apps Script (PSA form backend) ────────────────────────
APPS_SCRIPT_URL=                                # Deployed Apps Script /exec URL
SCRIPT_SECRET=                                  # Shared secret for form ↔ Apps Script auth

# ─── PSA API (cert lookups, status polling) ───────────────────────
PSA_API_TOKEN=                                  # Optional — only if integrating cert lookups

# ─── Shopify CLI / dev (optional) ─────────────────────────────────
SHOPIFY_FLAG_STORE=shoelessjoescards.myshopify.com
